  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-2546143129273595" crossorigin="anonymous"></script>
  <script is:inline>
  /* ─── Init all animations (runs on load + ViewTransitions swap) ─── */
  function initAnimations(){
    /* Scroll Reveal - only hide elements below the fold */
    var els = document.querySelectorAll('.reveal:not(.visible),.reveal-left:not(.visible),.reveal-right:not(.visible),.reveal-scale:not(.visible)');
    if (els.length) {
      var vh = window.innerHeight;
      els.forEach(function(el){
        var top = el.getBoundingClientRect().top;
        if (top > vh - 40) {
          el.classList.add('will-reveal');
        } else {
          el.classList.add('visible');
        }
      });
      var obs = new IntersectionObserver(function(entries){
        entries.forEach(function(e){ if(e.isIntersecting){ e.target.classList.add('visible'); obs.unobserve(e.target); }});
      }, {threshold:0.08, rootMargin:'50px 0px -20px 0px'});
      document.querySelectorAll('.will-reveal:not(.visible)').forEach(function(el){ obs.observe(el); });
    }

    /* Glow Card Mouse Tracking */
    document.querySelectorAll('.glow-card').forEach(function(card){
      if (card._glowBound) return;
      card._glowBound = true;
      card.addEventListener('mousemove', function(e){
        var r = card.getBoundingClientRect();
        card.style.setProperty('--mouse-x', (e.clientX - r.left) + 'px');
        card.style.setProperty('--mouse-y', (e.clientY - r.top) + 'px');
      });
    });

    /* Magnetic Buttons */
    document.querySelectorAll('.btn-magnetic').forEach(function(btn){
      if (btn._magBound) return;
      btn._magBound = true;
      btn.addEventListener('mousemove', function(e){
        var r = btn.getBoundingClientRect();
        var x = (e.clientX - r.left - r.width/2) * 0.15;
        var y = (e.clientY - r.top - r.height/2) * 0.15;
        btn.style.transform = 'translate('+x+'px,'+y+'px)';
      });
      btn.addEventListener('mouseleave', function(){ btn.style.transform = ''; });
    });

    /* Count-Up Animation */
    var countEls = document.querySelectorAll('[data-count]:not([data-counted])');
    if (countEls.length) {
      var cobs = new IntersectionObserver(function(entries){
        entries.forEach(function(e){
          if (!e.isIntersecting) return;
          var el = e.target;
          el.setAttribute('data-counted','1');
          var target = parseFloat(el.dataset.count), suffix = el.dataset.suffix || '', dur = 1200;
          var isInt = target === Math.floor(target), start = performance.now();
          function step(now){
            var p = Math.min((now - start) / dur, 1);
            p = 1 - Math.pow(1 - p, 3);
            el.textContent = (isInt ? Math.round(target * p) : (target * p).toFixed(1)) + suffix;
            if (p < 1) requestAnimationFrame(step);
          }
          requestAnimationFrame(step);
          cobs.unobserve(el);
        });
      }, {threshold:0.3});
      countEls.forEach(function(el){ cobs.observe(el); });
    }
  }

  /* Run on initial load */
  initAnimations();
  /* Re-run after Astro ViewTransitions page swap */
  document.addEventListener('astro:page-load', initAnimations);

  /* ─── Parallax on hero sections ─── */
  (function(){
    var heroes = document.querySelectorAll('.page-hero,.hero,.pt-hero,.live-hero');
    if (!heroes.length || window.innerWidth < 768) return;
    var ticking = false;
    window.addEventListener('scroll', function(){
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(function(){
        var s = window.scrollY;
        heroes.forEach(function(h){
          if (s < h.offsetTop + h.offsetHeight) {
            h.style.transform = 'translateY(' + (s * 0.15) + 'px)';
          }
        });
        ticking = false;
      });
    });
  })();

  /* ─── Cursor Glow ─── */
  (function(){
    var g = document.getElementById('cursor-glow');
    if (!g || window.innerWidth < 768) { if(g) g.style.display='none'; return; }
    document.addEventListener('mousemove', function(e){ g.style.left = e.clientX+'px'; g.style.top = e.clientY+'px'; });
  })();

  /* ─── Particles Background ─── */
  (function(){
    var c = document.getElementById('particles-bg');
    if (!c) return;
    var ctx = c.getContext('2d');
    var particles = [];
    function resize(){ c.width = window.innerWidth; c.height = window.innerHeight; }
    resize();
    window.addEventListener('resize', resize);
    for(var i = 0; i < 40; i++){
      particles.push({ x: Math.random()*c.width, y: Math.random()*c.height, vx: (Math.random()-0.5)*0.3, vy: (Math.random()-0.5)*0.3, r: Math.random()*1.5+0.5 });
    }
    function draw(){
      ctx.clearRect(0,0,c.width,c.height);
      ctx.fillStyle = 'rgba(0,232,123,0.15)';
      for(var i=0;i<particles.length;i++){
        var p = particles[i];
        p.x += p.vx; p.y += p.vy;
        if(p.x<0) p.x = c.width; if(p.x>c.width) p.x = 0;
        if(p.y<0) p.y = c.height; if(p.y>c.height) p.y = 0;
        ctx.beginPath(); ctx.arc(p.x,p.y,p.r,0,Math.PI*2); ctx.fill();
      }
      // Draw connections
      ctx.strokeStyle = 'rgba(0,232,123,0.04)';
      ctx.lineWidth = 0.5;
      for(var i=0;i<particles.length;i++){
        for(var j=i+1;j<particles.length;j++){
          var dx = particles[i].x-particles[j].x, dy = particles[i].y-particles[j].y;
          var dist = dx*dx+dy*dy;
          if(dist < 15000){
            ctx.beginPath(); ctx.moveTo(particles[i].x,particles[i].y); ctx.lineTo(particles[j].x,particles[j].y); ctx.stroke();
          }
        }
      }
      requestAnimationFrame(draw);
    }
    draw();
  })();
  </script>
