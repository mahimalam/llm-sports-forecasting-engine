---
import { ViewTransitions } from 'astro:transitions';
import TelegramLogin from '../components/TelegramLogin.astro';
const { title, description, image, matchId } = Astro.props;
const botUsername = "VexpMatchIQBot";
const tmaLink = matchId ? `https://t.me/${botUsername}?startapp=match_${matchId}` : `https://t.me/${botUsername}`;
const siteUrl = "https://vexp.me";
const ogImage = image || `${siteUrl}/og-default.png`;
const metaDesc = description || "FIFA World Cup 2026 predictions, live scores, and match analysis. Follow every game with MatchIQ.";
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="referrer" content="no-referrer-when-downgrade" />
  <meta name="cc935697d4cb4f77f0e217a176c6cfbb37a2a398" content="cc935697d4cb4f77f0e217a176c6cfbb37a2a398" />
  <title>{title} | MatchIQ</title>
  <meta name="description" content={metaDesc} />
  <meta name="google-site-verification" content="oeNMNfdCOW9rB2ruk8LLBXw7Kpck8Ux-rhsYDXkIkQA" />
  <meta name="msvalidate.01" content="8EFDF20C6B8A97B045AA9BE27D20FEB2" />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href={Astro.url.href} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={`${title} | MatchIQ`} />
  <meta property="og:description" content={metaDesc} />
  <meta property="og:url" content={Astro.url.href} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:site_name" content="MatchIQ" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={`${title} | MatchIQ`} />
  <meta name="twitter:description" content={metaDesc} />
  <meta name="twitter:image" content={ogImage} />

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

  <!-- Sitewide JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "MatchIQ",
    "url": "https://vexp.me",
    "description": "FIFA World Cup 2026 AI predictions, live scores, and match analysis.",
    "publisher": {
      "@type": "Organization",
      "name": "MatchIQ",
      "url": "https://vexp.me",
      "logo": { "@type": "ImageObject", "url": "https://vexp.me/apple-touch-icon.png" }
    }
  })} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@500;700&display=swap" rel="stylesheet" />
  <style is:inline>
    @keyframes slideOut { to { opacity: 0; transform: translateX(-12%); } }
    @keyframes slideIn { from { opacity: 0; transform: translateX(12%); } }
    ::view-transition-old(root) { animation: slideOut 0.5s cubic-bezier(0.4,0,0.2,1) both; }
    ::view-transition-new(root) { animation: slideIn 0.7s cubic-bezier(0,0,0.2,1) both; }
  </style>
  <ViewTransitions fallback="none" />
  <slot name="head" />
  <style is:global>
    /* ─── PAGE TRANSITION ANIMATION ─── */
    /* (moved to is:inline style below to prevent stripping) */

    :root {
      --bg-primary: #06060c;
      --bg-card: #0f0f1a;
      --bg-card-hover: #161625;
      --border: #1a1a2e;
      --text-primary: #f0f0f5;
      --text-secondary: #8a8aa3;
      --text-muted: #5a5a73;
      --accent: #00e87b;
      --accent-dim: rgba(0, 232, 123, 0.1);
      --danger: #ff4757;
      --warning: #ffa502;
      --radius: 12px;
      --radius-sm: 8px;
      --font-body: 'Inter', system-ui, sans-serif;
      --font-mono: 'JetBrains Mono', monospace;
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html { -webkit-font-smoothing: antialiased; scroll-behavior: smooth; }
    body { font-family: var(--font-body); background: var(--bg-primary); color: var(--text-primary); line-height: 1.6; min-height: 100vh; display: flex; flex-direction: column; justify-content: flex-start; }

    /* ─── NAV ─── */
    .nav { position: sticky; top: 0; z-index: 100; backdrop-filter: blur(16px) saturate(1.2); background: rgba(6,6,12,0.88); border-bottom: 1px solid var(--border); padding: 0 24px; }
    .nav-inner { max-width: 1200px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; height: 64px; }

    .nav-brand { display: flex; align-items: center; text-decoration: none; }
    .brand-logo { display: flex; align-items: center; }
    .nav-levitate { transform-origin: 80px 80px; animation: navFloat 4.5s ease-in-out infinite; }
    .nav-orbit-particles { transform-origin: 80px 80px; animation: navSpinRev 30s linear infinite; transition: stroke 0.5s ease; }
    .nav-orbit-base { transition: opacity 0.4s ease; }
    .nav-data-stream { transform-origin: 80px 80px; animation: navSpin 4s linear infinite; transition: stroke-dasharray 0.6s cubic-bezier(0.25,1,0.5,1), stroke-width 0.4s ease; }
    .nav-sonar { transform-origin: 80px 80px; opacity: 0; }
    .nav-ball-mesh { transform-origin: 45px 45px; transition: transform 1.2s cubic-bezier(0.2,0.9,0.3,1); }
    .nav-text-match { fill: url(#navPlatText); font-family: -apple-system,BlinkMacSystemFont,"Inter","Segoe UI",Roboto,sans-serif; font-weight: 900; font-size: 58px; letter-spacing: -1.5px; }
    .nav-text-iq { fill: #4ADE80; font-family: -apple-system,BlinkMacSystemFont,"Inter","Segoe UI",Roboto,sans-serif; font-weight: 900; font-size: 58px; letter-spacing: -0.5px; transition: filter 0.4s ease; }
    /* Hover state */
    .nav-brand:hover .nav-data-stream { stroke-dasharray: 180 160; stroke-width: 3.5; animation: navSpin 1.5s linear infinite; filter: url(#navNeon); }
    .nav-brand:hover .nav-orbit-particles { stroke: #4ADE80; opacity: 0.8; }
    .nav-brand:hover .nav-orbit-base { opacity: 0.1; }
    .nav-brand:hover .nav-sonar { animation: navPing 1.5s cubic-bezier(0.2,0.8,0.2,1) infinite; }
    .nav-brand:hover .nav-ball-mesh { transform: rotate(72deg) scale(1.02); }
    .nav-brand:hover .nav-text-iq { filter: url(#navNeon); }
    @keyframes navFloat { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-3px); } }
    @keyframes navSpin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
    @keyframes navSpinRev { from { transform: rotate(360deg); } to { transform: rotate(0deg); } }
    @keyframes navPing { 0% { transform: scale(0.9); opacity: 0.6; stroke-width: 2; } 100% { transform: scale(1.3); opacity: 0; stroke-width: 0; } }
    .brand-logo svg { position: relative; z-index: 1; }
    /* brand text is inside SVG now */

    .nav-links { display: flex; align-items: center; gap: 4px; }
    .nav-links a { color: var(--text-secondary); text-decoration: none; font-size: 13px; font-weight: 500; padding: 8px 14px; border-radius: var(--radius-sm); transition: all 150ms; }
    .nav-links a:hover { color: var(--text-primary); background: rgba(255,255,255,0.04); }
    .nav-live { color: var(--text-primary) !important; font-weight: 700 !important; display: inline-flex !important; align-items: center !important; gap: 6px !important; }
    .live-indicator { width: 6px; height: 6px; border-radius: 50%; background: #ff4444; box-shadow: 0 0 6px rgba(255,68,68,0.5); animation: livePulse 2s ease-in-out infinite; }
    @keyframes livePulse { 0%, 100% { opacity: 1; transform: scale(1); } 50% { opacity: 0.5; transform: scale(0.85); } }
    .nav-cta { background: var(--accent) !important; color: #000 !important; font-weight: 700 !important; display: inline-flex !important; align-items: center !important; gap: 6px !important; border-radius: 8px !important; }
    .nav-cta:hover { background: #00ff88 !important; transform: translateY(-1px); box-shadow: 0 4px 12px rgba(0,232,123,0.25); }
    .nav-vip { color: #ffc107 !important; font-weight: 700 !important; font-size: 12px !important; border: 1px solid rgba(255,193,7,0.3) !important; border-radius: 8px !important; background: rgba(255,193,7,0.06) !important; padding: 6px 12px !important; }
    .nav-vip:hover { background: rgba(255,193,7,0.14) !important; border-color: rgba(255,193,7,0.6) !important; transform: translateY(-1px); }

    /* ─── LAYOUT ─── */
    .container { max-width: 1200px; width: 100%; margin: 0 auto; padding: 32px 24px 64px; flex: 1; }

    /* ─── TYPOGRAPHY ─── */
    h1 { font-size: clamp(28px, 5vw, 42px); font-weight: 900; color: var(--text-primary); line-height: 1.1; letter-spacing: -0.03em; }
    h2 { font-size: 20px; font-weight: 700; color: var(--text-primary); margin: 32px 0 16px; display: flex; align-items: center; gap: 8px; }
    h2::after { content: ''; flex: 1; height: 1px; background: var(--border); margin-left: 12px; }
    h3 { font-size: 16px; font-weight: 600; color: var(--text-primary); margin-bottom: 8px; }
    p { color: var(--text-secondary); margin-bottom: 16px; }

    /* ─── COMPONENTS ─── */
    .card { background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius); padding: 20px; transition: border-color 200ms, transform 200ms, box-shadow 200ms; }
    .card:hover { border-color: rgba(0,232,123,0.3); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.3); }

    .prob-bar { display: flex; height: 36px; border-radius: var(--radius-sm); overflow: hidden; font-family: var(--font-mono); font-size: 12px; font-weight: 500; }
    .prob-bar > div { display: flex; align-items: center; justify-content: center; color: #fff; min-width: 40px; transition: width 600ms cubic-bezier(0.4,0,0.2,1); }
    .prob-home { background: var(--accent); color: #000; }
    .prob-draw { background: var(--text-muted); }
    .prob-away { background: var(--danger); }

    table { width: 100%; border-collapse: collapse; margin: 16px 0; font-variant-numeric: tabular-nums; }
    th, td { padding: 10px 16px; text-align: left; font-size: 14px; border-bottom: 1px solid var(--border); }
    th { color: var(--text-muted); font-weight: 500; font-size: 12px; text-transform: uppercase; letter-spacing: 0.05em; }

    .stat-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 12px; margin: 16px 0; }
    .stat-item { background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius-sm); padding: 16px; text-align: center; }
    .stat-value { font-family: var(--font-mono); font-size: 24px; font-weight: 700; color: var(--accent); }
    .stat-label { font-size: 12px; color: var(--text-muted); text-transform: uppercase; margin-top: 4px; }

    .badge { display: inline-flex; align-items: center; gap: 4px; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; padding: 4px 10px; border-radius: 20px; background: var(--accent-dim); color: var(--accent); }

    .cta-block { display: flex; align-items: center; gap: 16px; background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius); padding: 20px 24px; margin: 32px 0; text-decoration: none; transition: all 200ms; position: relative; overflow: hidden; }
    .cta-block::before { content: ''; position: absolute; inset: 0; background: linear-gradient(135deg, transparent, rgba(0,232,123,0.03)); opacity: 0; transition: opacity 200ms; }
    .cta-block:hover { border-color: var(--accent); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.2); }
    .cta-block:hover::before { opacity: 1; }
    .cta-icon { position: relative; z-index: 1; }
    .cta-text { position: relative; z-index: 1; }
    .cta-text h3 { margin: 0; color: var(--text-primary); }
    .cta-text p { margin: 4px 0 0; font-size: 13px; color: var(--text-secondary); }
    .cta-arrow { margin-left: auto; color: var(--accent); font-size: 20px; position: relative; z-index: 1; transition: transform 200ms; }
    .cta-block:hover .cta-arrow { transform: translateX(4px); }

    .ad-slot { margin: 24px 0; min-height: 90px; text-align: center; }

    /* ─── FOOTER ─── */
    .site-footer { border-top: 1px solid var(--border); background: var(--bg-card); padding: 48px 24px 32px; margin-top: auto; }
    .footer-inner { max-width: 1200px; margin: 0 auto; }
    .footer-top { display: flex; align-items: flex-start; justify-content: space-between; gap: 40px; margin-bottom: 32px; }
    .footer-brand { display: flex; flex-direction: column; gap: 12px; }
    .footer-logo { display: flex; align-items: center; gap: 10px; }
    .footer-logo-icon { width: 28px; height: 28px; border-radius: 7px; background: linear-gradient(135deg, var(--accent), #00b861); display: flex; align-items: center; justify-content: center; }
    .footer-logo-text { font-size: 16px; font-weight: 800; letter-spacing: -0.3px; color: var(--text-primary); }
    .footer-logo-text span { color: var(--accent); }
    .footer-tagline { font-size: 12px; color: var(--text-muted); max-width: 280px; line-height: 1.5; }
    .footer-links { display: flex; gap: 32px; }
    .footer-col h4 { font-size: 11px; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 10px; }
    .footer-col a { display: block; font-size: 13px; color: var(--text-secondary); text-decoration: none; padding: 3px 0; transition: color 150ms; }
    .footer-col a:hover { color: var(--accent); }
    .footer-bottom { border-top: 1px solid var(--border); padding-top: 20px; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px; }
    .footer-copy { font-size: 12px; color: var(--text-muted); }
    .footer-powered { font-size: 12px; color: var(--text-muted); display: flex; align-items: center; gap: 6px; }
    .footer-powered strong { color: var(--text-secondary); font-weight: 700; }

    /* ─── GLOBAL CONTENT ─── */
    main :global(p) { color: var(--text-secondary); line-height: 1.7; margin-bottom: 16px; }
    main :global(strong) { color: var(--text-primary); font-weight: 600; }
    main :global(a) { color: var(--accent); text-decoration: none; }

    /* ─── SCROLL REVEAL ─── */
    .reveal, .reveal-left, .reveal-right, .reveal-scale { transition: opacity 0.7s cubic-bezier(0.16,1,0.3,1), transform 0.7s cubic-bezier(0.16,1,0.3,1); }
    .reveal.will-reveal { opacity: 0; transform: translateY(30px); }
    .reveal-left.will-reveal { opacity: 0; transform: translateX(-40px); }
    .reveal-right.will-reveal { opacity: 0; transform: translateX(40px); }
    .reveal-scale.will-reveal { opacity: 0; transform: scale(0.9); }
    .reveal.visible, .reveal-left.visible, .reveal-right.visible, .reveal-scale.visible { opacity: 1 !important; transform: none !important; }
    .stagger-1 { transition-delay: 0.08s; }
    .stagger-2 { transition-delay: 0.16s; }
    .stagger-3 { transition-delay: 0.24s; }
    .stagger-4 { transition-delay: 0.32s; }
    .stagger-5 { transition-delay: 0.4s; }
    .stagger-6 { transition-delay: 0.48s; }

    /* ─── GLOW CARD ─── */
    .glow-card { position: relative; overflow: hidden; }
    .glow-card::before { content: ''; position: absolute; width: 200px; height: 200px; background: radial-gradient(circle, rgba(0,232,123,0.15), transparent 70%); border-radius: 50%; pointer-events: none; opacity: 0; transition: opacity 0.3s; transform: translate(-50%, -50%); top: var(--mouse-y, 50%); left: var(--mouse-x, 50%); }
    .glow-card:hover::before { opacity: 1; }
    .glow-card:hover { border-color: rgba(0,232,123,0.4) !important; }

    /* ─── ANIMATED PARTICLES BG ─── */
    #particles-bg { position: fixed; inset: 0; z-index: -1; pointer-events: none; }

    /* ─── CURSOR GLOW TRAIL ─── */
    .cursor-glow { position: fixed; width: 300px; height: 300px; border-radius: 50%; background: radial-gradient(circle, rgba(0,232,123,0.06) 0%, transparent 70%); pointer-events: none; z-index: 0; transform: translate(-50%, -50%); transition: left 0.15s ease-out, top 0.15s ease-out; }

    /* ─── FLOATING FOOTBALLS ─── */
    .floating-icons { position: fixed; inset: 0; pointer-events: none; z-index: -1; overflow: hidden; }
    .floating-icon { position: absolute; font-size: 20px; opacity: 0.04; animation: floatUp 15s linear infinite; }
    @keyframes floatUp { 0% { transform: translateY(100vh) rotate(0deg); opacity: 0; } 10% { opacity: 0.04; } 90% { opacity: 0.04; } 100% { transform: translateY(-100px) rotate(360deg); opacity: 0; } }

    /* ─── GRADIENT BORDER ANIMATION ─── */
    .gradient-border { position: relative; border: none !important; }
    .gradient-border::before { content: ''; position: absolute; inset: -1px; border-radius: inherit; padding: 1px; background: linear-gradient(var(--gradient-angle, 0deg), var(--accent), transparent, var(--accent)); mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0); mask-composite: exclude; -webkit-mask-composite: xor; animation: rotateGradient 4s linear infinite; pointer-events: none; }
    @keyframes rotateGradient { 0% { --gradient-angle: 0deg; } 100% { --gradient-angle: 360deg; } }
    @property --gradient-angle { syntax: '<angle>'; initial-value: 0deg; inherits: false; }

    /* ─── INTERACTIVE ANIMATED ICONS ─── */
    .icon-animated { display: inline-flex; align-items: center; justify-content: center; transition: transform 0.3s cubic-bezier(0.34,1.56,0.64,1); }
    .icon-animated:hover { transform: scale(1.2) rotate(-5deg); }
    .icon-bounce { animation: iconBounce 2s ease-in-out infinite; }
    @keyframes iconBounce { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-4px); } }
    .icon-pulse { animation: iconPulse 2s ease-in-out infinite; }
    @keyframes iconPulse { 0%, 100% { transform: scale(1); opacity: 1; } 50% { transform: scale(1.1); opacity: 0.8; } }
    .icon-spin-hover:hover svg { animation: iconSpin 0.6s cubic-bezier(0.34,1.56,0.64,1); }
    @keyframes iconSpin { 0% { transform: rotate(0); } 100% { transform: rotate(360deg); } }

    /* ─── SHIMMER TEXT ─── */
    .shimmer-text { background: linear-gradient(90deg, var(--text-primary) 0%, var(--accent) 50%, var(--text-primary) 100%); background-size: 200% 100%; -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; animation: shimmer 3s ease-in-out infinite; }
    @keyframes shimmer { 0%, 100% { background-position: 100% 0; } 50% { background-position: -100% 0; } }

    /* ─── MAGNETIC BUTTON ─── */
    .btn-magnetic { transition: transform 0.2s cubic-bezier(0.34,1.56,0.64,1), box-shadow 0.3s; }
    .btn-magnetic:hover { box-shadow: 0 8px 40px rgba(0,232,123,0.35), 0 0 80px rgba(0,232,123,0.1); }

    /* ─── HOVER LIFT CARD ─── */
    .hover-3d { transition: transform 0.3s cubic-bezier(0.34,1.56,0.64,1), box-shadow 0.3s; }
    .hover-3d:hover { transform: translateY(-6px) rotateX(2deg); box-shadow: 0 20px 40px rgba(0,0,0,0.4), 0 0 30px rgba(0,232,123,0.08); }

    /* ─── TYPEWRITER BADGE ─── */
    .badge-glow { animation: badgeGlow 2.5s ease-in-out infinite alternate; }
    @keyframes badgeGlow { 0% { box-shadow: 0 0 8px rgba(0,232,123,0.2), inset 0 0 8px rgba(0,232,123,0.05); } 100% { box-shadow: 0 0 20px rgba(0,232,123,0.4), inset 0 0 12px rgba(0,232,123,0.1); } }

    /* ─── ANIMATIONS ─── */
    @keyframes fadeUp { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }
    .animate-in { animation: fadeUp 400ms ease-out both; }
    .delay-1 { animation-delay: 100ms; }
    .delay-2 { animation-delay: 200ms; }
    .delay-3 { animation-delay: 300ms; }
    .delay-4 { animation-delay: 400ms; }

    /* ─── TICKER MARQUEE ─── */
    .ticker-wrap { overflow: hidden; white-space: nowrap; background: rgba(0,232,123,0.04); border-bottom: 1px solid var(--border); padding: 8px 0; }
    .ticker-wrap:hover .ticker-track { animation-play-state: paused; }
    .ticker-track { display: inline-flex; animation: tickerScroll 40s linear infinite; }
    .ticker-item { display: inline-flex; align-items: center; gap: 6px; padding: 0 24px; font-size: 12px; color: var(--text-secondary); font-weight: 500; }
    .ticker-item img { width: 16px; height: 12px; border-radius: 2px; object-fit: cover; }
    .ticker-vs { color: var(--text-muted); font-weight: 700; font-size: 10px; margin: 0 4px; }
    .ticker-time { color: var(--accent); font-family: var(--font-mono); font-size: 10px; margin-left: 6px; }
    @keyframes tickerScroll { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }

    /* ─── NAV MICRO-INTERACTIONS ─── */
    .nav-links a { position: relative; }
    .nav-links a::after { content: ''; position: absolute; bottom: 2px; left: 50%; width: 0; height: 2px; background: var(--accent); border-radius: 1px; transition: width 0.3s cubic-bezier(0.16,1,0.3,1), left 0.3s cubic-bezier(0.16,1,0.3,1); }
    .nav-links a:hover::after { width: 60%; left: 20%; }

    /* ─── BUTTON PULSE ─── */
    .btn-primary, .nav-cta { position: relative; overflow: hidden; }
    .btn-primary::after, .nav-cta::after { content: ''; position: absolute; inset: 0; background: linear-gradient(135deg, rgba(255,255,255,0.2), transparent); opacity: 0; transition: opacity 0.3s; }
    .btn-primary:hover::after, .nav-cta:hover::after { opacity: 1; }

    /* ─── SMOOTH TAB TRANSITIONS ─── */
    .tab-panel { transition: opacity 0.35s ease; }
    .tab-panel.hidden { display: none; }

    /* ─── FLIP COUNTDOWN ─── */
    .flip-num { display: inline-block; perspective: 200px; }
    .flip-num .cd-num { transition: transform 0.4s cubic-bezier(0.16,1,0.3,1); backface-visibility: hidden; }
    .flip-num.flipping .cd-num { animation: flipDigit 0.4s cubic-bezier(0.16,1,0.3,1); }
    @keyframes flipDigit { 0% { transform: rotateX(0); } 50% { transform: rotateX(-90deg); opacity: 0.5; } 100% { transform: rotateX(0); } }

    /* ─── RESPONSIVE ─── */
    /* ─── MOBILE TAB BAR ─── */
