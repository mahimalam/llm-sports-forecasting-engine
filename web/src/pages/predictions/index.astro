---
import BaseLayout from "../../layouts/BaseLayout.astro";

const matchFiles = await Astro.glob('./*.md');
const matches = matchFiles
  .map(m => ({ ...m.frontmatter, slug: m.file.split('/').pop().replace('.md', '') }))
  .sort((a, b) => `${a.date}${a.time || '00:00'}`.localeCompare(`${b.date}${b.time || '00:00'}`));

const FLAGS: Record<string, string> = {"Mexico":"mx","South Africa":"za","Canada":"ca","Bosnia-Herzegovina":"ba","South Korea":"kr","Czechia":"cz","Brazil":"br","Morocco":"ma","Qatar":"qa","Switzerland":"ch","United States":"us","Paraguay":"py","Argentina":"ar","France":"fr","Germany":"de","Spain":"es","England":"gb-eng","Portugal":"pt","Netherlands":"nl","Belgium":"be","Italy":"it","Croatia":"hr","Uruguay":"uy","Colombia":"co","Japan":"jp","Senegal":"sn","Australia":"au","Poland":"pl","Denmark":"dk","Serbia":"rs","Ecuador":"ec","Iran":"ir","Nigeria":"ng","Saudi Arabia":"sa","Peru":"pe","Ghana":"gh","Cameroon":"cm","Tunisia":"tn","Costa Rica":"cr","Panama":"pa","Chile":"cl","Egypt":"eg","Algeria":"dz","Turkey":"tr","Scotland":"gb-sct","Norway":"no","Sweden":"se","Jamaica":"jm","Honduras":"hn","New Zealand":"nz","Albania":"al","Indonesia":"id","Ukraine":"ua","Austria":"at","Slovenia":"si","Slovakia":"sk","Romania":"ro","Hungary":"hu","Greece":"gr","Bolivia":"bo","Venezuela":"ve","Ivory Coast":"ci","Mali":"ml","DR Congo":"cd","Trinidad and Tobago":"tt","Uzbekistan":"uz","Wales":"gb-wls","Ireland":"ie","Iceland":"is","Finland":"fi","Haiti":"ht","Curaçao":"cw","Cape Verde Islands":"cv","Jordan":"jo","Iraq":"iq"};
const flagUrl = (t: string) => `https://flagcdn.com/w80/${FLAGS[t] || 'un'}.png`;
const fmtDate = (d: string) => new Date(d + 'T00:00:00').toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric' });

// Group by date
const grouped: Record<string, typeof matches> = {};
matches.forEach(m => { (grouped[m.date] ||= []).push(m); });
const dates = Object.keys(grouped).sort();
---
<BaseLayout title="FIFA World Cup 2026 Match Predictions" description="Free match predictions for every FIFA World Cup 2026 game. Win probabilities, score forecasts, and expert picks updated before each kickoff.">

  <section class="page-hero reveal">
    <span class="icon-animated icon-pulse"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round"><path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/></svg></span>
    <h1 class="hero-h1 shimmer-text">Match Predictions</h1>
    <p class="hero-tag">AI-Powered · Multi-Factor Model · Real-Time Updates · Win Probabilities</p>
  </section>

  <div id="acc-banner"></div>

  <!-- SUB-TABS: Upcoming / Predicted -->
  <div class="pred-tabs" id="pred-tabs" style="opacity:0;transition:opacity 0.08s">
    <button class="pred-tab active" data-ptab="upcoming">Upcoming</button>
    <button class="pred-tab" data-ptab="predicted">Predicted</button>
  </div>
  <div id="gate-overlay" class="gate-overlay" style="display:none">
    <div class="gate-card">
      <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="1.5"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/><circle cx="12" cy="16" r="1"/></svg>
      <h3 class="gate-title">Login to View Predictions</h3>
      <p class="gate-sub">Connect your Telegram account to access AI predictions for every match.</p>
      <button class="gate-login-btn" onclick="startTgLogin()">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.64 6.8c-.15 1.58-.8 5.42-1.13 7.19-.14.75-.42 1-.68 1.03-.58.05-1.02-.38-1.58-.75-.88-.58-1.38-.94-2.23-1.5-.99-.65-.35-1.01.22-1.59.15-.15 2.71-2.48 2.76-2.69a.2.2 0 00-.05-.18c-.06-.05-.14-.03-.21-.02-.09.02-1.49.95-4.22 2.79-.4.27-.76.41-1.08.4-.36-.01-1.04-.2-1.55-.37-.63-.2-1.12-.31-1.08-.66.02-.18.27-.36.74-.55 2.92-1.27 4.86-2.11 5.83-2.51 2.78-1.16 3.35-1.36 3.73-1.36.08 0 .27.02.39.12.1.08.13.19.14.27-.01.06.01.24 0 .38z" fill="#29B6F6"/></svg>
        Login with Telegram
      </button>
      <div class="gate-divider"><span>or</span></div>
      <a class="gate-vip-btn" href="https://t.me/VexpMatchIQBot?start=vip" target="_blank">
        ⭐ Get VIP — 250 Stars
        <span class="gate-vip-sub">Unlock all 104 predictions forever. No ads.</span>
      </a>
      <p class="gate-note">Free users: watch 2 ads to unlock each match prediction.</p>
    </div>
  </div>

  <!-- Ad watching overlay -->
  <div id="ad-overlay" class="ad-overlay" style="display:none">
    <div class="ad-card">
      <span class="ad-count">Ad 1 of 2</span>
      <div class="ad-video-wrap" id="ad-video-wrap">
        <video id="ad-video" playsinline></video>
        <div id="ad-container"></div>
      </div>
      <div class="ad-timer" id="ad-timer">
        <div class="ad-progress-bar"><div class="ad-progress-fill" id="ad-progress-fill"></div></div>
        <span id="ad-countdown-text">Loading ad...</span>
      </div>
      <button class="ad-done-btn" id="ad-done-btn" style="display:none" onclick="onAdWatched()">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
        Continue
      </button>
    </div>
  </div>

  <div id="panel-upcoming">
  {dates.map((date, di) => (
    <section class="day-group reveal" data-date={date}>
      <div class="day-header">
        <span class="day-dot"></span>
        <span class="day-date">{fmtDate(date)}</span>
        <span class="day-count">{grouped[date].length} {grouped[date].length === 1 ? 'match' : 'matches'}</span>
      </div>
      <div class="pred-cards">
        {grouped[date].map((m, mi) => {
          const h = parseFloat(m.homeWin), d = parseFloat(m.draw), a = parseFloat(m.awayWin);
          const pick = h > a ? m.homeTeam : a > h ? m.awayTeam : 'Draw';
          const conf = Math.max(h, d, a);
          return (
            <a href={`/predictions/${m.slug}/`} class={`pred-card glow-card hover-3d reveal stagger-${mi+1}`}>
              <div class="pred-header">
                <div class="pred-team">
                  <img class="pred-flag" src={flagUrl(m.homeTeam)} alt={m.homeTeam} loading="lazy" />
                  <span class="pred-name">{m.homeTeam}</span>
                </div>
                <div class="pred-vs">
                  <span class="pred-time">{m.time} IST</span>
                  <span class="pred-vstext shimmer-text">VS</span>
                </div>
                <div class="pred-team pred-team-right">
                  <img class="pred-flag" src={flagUrl(m.awayTeam)} alt={m.awayTeam} loading="lazy" />
                  <span class="pred-name">{m.awayTeam}</span>
                </div>
              </div>

              <div class="pred-probs">
                <div class="prob-item">
                  <span class="prob-label">{m.homeTeam}</span>
                  <div class="prob-bar"><div class="prob-fill home" data-width={h} style="width:0%"></div></div>
                  <span class="prob-pct" data-count={h} data-suffix="%">0%</span>
                </div>
                <div class="prob-item">
                  <span class="prob-label">Draw</span>
                  <div class="prob-bar"><div class="prob-fill draw" data-width={d} style="width:0%"></div></div>
                  <span class="prob-pct" data-count={d} data-suffix="%">0%</span>
                </div>
                <div class="prob-item">
                  <span class="prob-label">{m.awayTeam}</span>
                  <div class="prob-bar"><div class="prob-fill away" data-width={a} style="width:0%"></div></div>
                  <span class="prob-pct" data-count={a} data-suffix="%">0%</span>
                </div>
              </div>

              <div class="pred-pick">
                <span class="pick-chip">{pick}</span>
                <span class="pick-conf">{conf.toFixed(0)}% confidence</span>
                <span class="pred-arrow"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg></span>
              </div>
            </a>
          );
        })}
      </div>
    </section>
  ))}
  </div><!-- /panel-upcoming -->

  <!-- PREDICTED panel: filled by JS from /api/matches -->
  <div id="panel-predicted" style="display:none">
    <p class="empty-state">Loading finished match predictions...</p>
  </div>

</BaseLayout>

<style is:global>
  /* Global styles for JS-created elements */
  .pred-lock-overlay { display: flex; align-items: center; justify-content: center; gap: 8px; padding: 20px; margin-top: 12px; border-radius: 12px; background: rgba(74,222,128,0.04); border: 1px dashed rgba(74,222,128,0.3); color: var(--accent); font-size: 13px; font-weight: 600; cursor: pointer; transition: all 0.2s; }
  .pred-lock-overlay:hover { background: rgba(74,222,128,0.08); border-color: var(--accent); }

  /* Track record banner */
  .wp-acc-banner { background: linear-gradient(135deg, rgba(0,232,123,0.08), rgba(0,232,123,0.03)); border: 1px solid rgba(0,232,123,0.2); border-radius: 14px; padding: 16px 20px; margin-bottom: 24px; }
  .wp-acc-row { display: flex; align-items: center; gap: 8px; margin-bottom: 10px; }
  .wp-acc-title { font-size: 14px; font-weight: 700; color: var(--text-primary); }
  .wp-acc-stats { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
  .wp-acc-stat { font-size: 13px; color: var(--text-secondary); font-weight: 600; }
  .wp-acc-hl { color: var(--accent); font-size: 28px; font-weight: 900; line-height: 1; }
  .wp-acc-dot { width: 4px; height: 4px; border-radius: 50%; background: var(--border); flex-shrink: 0; }

  /* Sub-tabs */
  .pred-tabs { display: flex; gap: 8px; margin-bottom: 24px; padding: 4px; background: var(--bg-card); border-radius: 12px; border: 1px solid var(--border); }
  .pred-tab { flex: 1; padding: 10px; font-size: 13px; font-weight: 700; border: none; border-radius: 10px; background: transparent; color: var(--text-muted); cursor: pointer; transition: all 150ms; }
  .pred-tab.active { background: var(--accent); color: #000; }
  .pred-tab:not(.active):hover { color: var(--text-primary); }

  /* Predicted panel shared layout */
  .empty-state { text-align: center; padding: 40px 20px; color: var(--text-muted); font-size: 14px; }
  .pred-day-group { margin-bottom: 32px; }
  .pred-day-header { display: flex; align-items: center; gap: 10px; margin-bottom: 14px; padding: 10px 16px; background: rgba(255,255,255,0.02); border-radius: 10px; border-left: 3px solid var(--border); }
  .pred-day-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--text-muted); }
  .pred-day-date { font-size: 14px; font-weight: 700; color: var(--text-primary); }
  .pred-day-count { font-size: 11px; color: var(--text-muted); margin-left: auto; background: rgba(255,255,255,0.05); padding: 3px 8px; border-radius: 12px; }
  .pred-day-cards { display: flex; flex-direction: column; gap: 12px; }

  /* Predicted card — clickable link */
  .predicted-card { display: block; text-decoration: none; background: var(--bg-card); border: 1px solid var(--border); border-radius: 16px; padding: 20px; transition: border-color 0.2s, transform 0.15s; cursor: pointer; }
  .predicted-card:hover { border-color: rgba(0,232,123,0.3); transform: translateY(-1px); }
  .predicted-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; background: linear-gradient(90deg, transparent, rgba(0,232,123,0.4), transparent); opacity: 0; transition: opacity 0.3s; }
  .predicted-card:hover::before { opacity: 1; }
  .pc-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 14px; }
  .pc-team { display: flex; align-items: center; gap: 10px; flex: 1; }
  .pc-team-right { flex-direction: row-reverse; }
  .pc-flag { width: 36px; height: 26px; border-radius: 4px; object-fit: cover; box-shadow: 0 2px 8px rgba(0,0,0,0.3); }
  .pc-name { font-size: 15px; font-weight: 800; color: var(--text-primary); }
  .pc-center { text-align: center; padding: 0 12px; }
  .pc-score { font-size: 22px; font-weight: 900; color: var(--text-primary); letter-spacing: 3px; display: block; }
  .pc-ft { font-size: 10px; color: var(--text-muted); display: block; margin-top: 2px; font-family: monospace; letter-spacing: 1px; }
  .pc-winner-row { display: flex; align-items: center; gap: 10px; padding: 10px 14px; background: rgba(0,232,123,0.04); border: 1px solid rgba(0,232,123,0.12); border-radius: 10px; }
  .pc-winner-chip { font-size: 13px; font-weight: 800; color: var(--accent); padding: 2px 10px; background: rgba(0,232,123,0.1); border-radius: 6px; }
  .pc-confirmed { font-size: 11px; color: var(--text-muted); margin-left: auto; }
  .pc-arrow { color: var(--text-muted); opacity: 0; transition: all 0.2s; }
  .predicted-card:hover .pc-arrow { opacity: 1; color: var(--accent); }

  @media (max-width: 640px) {
    .pc-name { font-size: 12px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .pc-flag { width: 24px; height: 18px; }
    .pc-center { padding: 0 6px; }
  }
</style>
<style>
  .page-hero { text-align: center; padding: 40px 0 28px; max-width: 620px; margin: 0 auto; }
  .hero-h1 { font-size: clamp(26px, 5vw, 36px); font-weight: 900; margin: 0 0 6px; }
  .hero-h1::after { display: none; }
  .hero-sub { font-size: 13px; font-weight: 600; color: var(--accent); margin: 0 0 14px; letter-spacing: 0.3px; }
  .hero-p { font-size: 14px; color: var(--text-secondary); margin: 0 0 12px; line-height: 1.7; }
  .hero-tag { font-size: 11px; font-weight: 700; color: var(--text-muted); letter-spacing: 0.5px; text-transform: uppercase; margin: 0; }

  .day-group { margin-bottom: 32px; }
  .day-header { display: flex; align-items: center; gap: 10px; margin-bottom: 14px; padding: 10px 16px; background: rgba(0,232,123,0.03); border-radius: 10px; border-left: 3px solid var(--accent); }
  .day-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--accent); box-shadow: 0 0 8px rgba(0,232,123,0.5); animation: iconPulse 2s ease-in-out infinite; }
  .day-date { font-size: 14px; font-weight: 700; color: var(--text-primary); }
  .day-count { font-size: 11px; color: var(--text-muted); margin-left: auto; background: rgba(255,255,255,0.05); padding: 3px 8px; border-radius: 12px; }

  .pred-cards { display: flex; flex-direction: column; gap: 16px; }

  .pred-card { display: block; text-decoration: none; background: var(--bg-card); border: 1px solid var(--border); border-radius: 16px; padding: 20px; transition: all 250ms cubic-bezier(0.34,1.56,0.64,1); position: relative; }
  .pred-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; background: linear-gradient(90deg, transparent, var(--accent), transparent); opacity: 0; transition: opacity 0.3s; }
  .pred-card:hover::before { opacity: 1; }
  .pred-card:hover { border-color: rgba(0,232,123,0.3); }

  .pred-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; }
  .pred-team { display: flex; align-items: center; gap: 10px; flex: 1; }
  .pred-team-right { flex-direction: row-reverse; }
  .pred-flag { width: 36px; height: 26px; border-radius: 4px; object-fit: cover; box-shadow: 0 2px 8px rgba(0,0,0,0.3); transition: transform 0.3s; }
  .pred-card:hover .pred-flag { transform: scale(1.1); }
  .pred-name { font-size: 15px; font-weight: 800; color: var(--text-primary); }
  .pred-vs { text-align: center; padding: 0 12px; }
  .pred-time { display: block; font-size: 10px; color: var(--text-muted); font-family: var(--font-mono); }
  .pred-vstext { font-size: 11px; font-weight: 800; color: var(--text-muted); }

  .pred-probs { display: flex; flex-direction: column; gap: 8px; margin-bottom: 14px; }
  .prob-item { display: flex; align-items: center; gap: 8px; }
  .prob-label { font-size: 11px; color: var(--text-secondary); width: 80px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .prob-bar { flex: 1; height: 8px; background: rgba(255,255,255,0.06); border-radius: 4px; overflow: hidden; position: relative; }
  .prob-fill { height: 100%; border-radius: 4px; transition: width 1.2s cubic-bezier(0.16,1,0.3,1); position: relative; }
  .prob-fill::after { content: ''; position: absolute; inset: 0; background: linear-gradient(90deg, transparent 0%, rgba(255,255,255,0.25) 50%, transparent 100%); animation: barShine 2s ease-in-out infinite; }
  @keyframes barShine { 0%,100% { transform: translateX(-100%); } 50% { transform: translateX(100%); } }
  .prob-fill.home { background: linear-gradient(90deg, #00e87b, #00c868); }
  .prob-fill.draw { background: linear-gradient(90deg, #fbbf24, #f59e0b); }
  .prob-fill.away { background: linear-gradient(90deg, #60a5fa, #3b82f6); }
  .prob-pct { font-size: 12px; font-weight: 700; color: var(--text-primary); width: 44px; text-align: right; font-family: var(--font-mono); }

  .pred-pick { display: flex; align-items: center; gap: 10px; padding: 10px 14px; background: rgba(0,232,123,0.04); border: 1px solid rgba(0,232,123,0.12); border-radius: 10px; }
  .pick-chip { font-size: 13px; font-weight: 800; color: var(--accent); padding: 2px 10px; background: rgba(0,232,123,0.1); border-radius: 6px; }
  .pick-conf { font-size: 11px; color: var(--text-muted); }
  .pred-arrow { margin-left: auto; color: var(--text-muted); opacity: 0; transition: all 0.3s; transform: translateX(-4px); }
  .pred-card:hover .pred-arrow { opacity: 1; color: var(--accent); transform: translateX(0); }

  @media (max-width: 640px) {
    .pred-header { flex-wrap: nowrap; gap: 4px; }
    .pred-team { gap: 6px; min-width: 0; }
    .pred-flag { width: 24px; height: 18px; flex-shrink: 0; }
    .pred-name { font-size: 12px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .pred-vs { padding: 0 6px; flex-shrink: 0; }
    .prob-label { width: 50px; font-size: 10px; }
  }

  .gate-overlay { position: fixed; inset: 0; z-index: 100; background: rgba(6,6,12,0.85); backdrop-filter: blur(8px); display: flex; align-items: center; justify-content: center; padding: 20px; }
  .gate-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 20px; padding: 40px 30px; text-align: center; max-width: 380px; }
  .gate-title { font-size: 18px; font-weight: 800; color: var(--text-primary); margin: 16px 0 8px; }
  .gate-sub { font-size: 13px; color: var(--text-secondary); margin: 0 0 20px; line-height: 1.5; }
  .gate-login-btn { display: inline-flex; align-items: center; gap: 8px; padding: 12px 24px; background: rgba(41,182,246,0.1); border: 1px solid rgba(41,182,246,0.3); border-radius: 24px; color: #29B6F6; font-size: 14px; font-weight: 700; cursor: pointer; transition: all 0.2s; }
  .gate-login-btn:hover { background: rgba(41,182,246,0.2); border-color: rgba(41,182,246,0.5); transform: translateY(-1px); }
  .gate-divider { display: flex; align-items: center; gap: 10px; color: var(--text-muted); font-size: 11px; margin: 14px 0; }
  .gate-divider::before, .gate-divider::after { content: ''; flex: 1; height: 1px; background: var(--border); }
  .gate-vip-btn { display: flex; flex-direction: column; align-items: center; gap: 4px; padding: 14px 24px; background: linear-gradient(135deg, rgba(255,193,7,0.1), rgba(255,152,0,0.05)); border: 1px solid rgba(255,193,7,0.35); border-radius: 14px; color: #ffc107; font-size: 15px; font-weight: 800; text-decoration: none; transition: all 0.2s; width: 100%; text-align: center; }
  .gate-vip-btn:hover { background: linear-gradient(135deg, rgba(255,193,7,0.18), rgba(255,152,0,0.1)); border-color: rgba(255,193,7,0.6); transform: translateY(-1px); box-shadow: 0 4px 16px rgba(255,193,7,0.15); }
  .gate-vip-sub { font-size: 11px; color: var(--text-muted); font-weight: 500; }
  .gate-note { font-size: 11px; color: var(--text-muted); margin: 14px 0 0; }

  .ad-overlay { position: fixed; inset: 0; z-index: 200; background: rgba(6,6,12,0.92); backdrop-filter: blur(6px); display: flex; align-items: center; justify-content: center; }
  .ad-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 20px; padding: 24px; text-align: center; max-width: 400px; width: 90%; }
  .ad-count { font-size: 11px; font-weight: 800; color: var(--accent); letter-spacing: 0.5px; text-transform: uppercase; }
  .ad-video-wrap { position: relative; width: 100%; aspect-ratio: 16/9; background: #000; border-radius: 12px; overflow: hidden; margin: 16px 0; }
  .ad-video-wrap video { width: 100%; height: 100%; object-fit: contain; }
  #ad-container { position: absolute; inset: 0; }
  @media (max-width: 640px) {
    .ad-card { padding: 16px; max-width: 95%; }
    .ad-video-wrap { aspect-ratio: 4/3; }
    .pred-lock-overlay { font-size: 12px; padding: 16px; }
  }
  .ad-timer { margin-bottom: 16px; }
  .ad-progress-bar { height: 4px; background: rgba(255,255,255,0.06); border-radius: 4px; overflow: hidden; margin-bottom: 8px; }
  .ad-progress-fill { height: 100%; background: var(--accent); border-radius: 4px; transition: width 0.1s linear; }
  #ad-countdown-text { font-size: 11px; color: var(--text-muted); }
  .ad-done-btn { display: inline-flex; align-items: center; gap: 8px; padding: 12px 28px; background: var(--accent); border: none; border-radius: 24px; color: #06060c; font-size: 14px; font-weight: 800; cursor: pointer; transition: transform 0.2s; }
  .ad-done-btn:hover { transform: scale(1.05); }
  .ad-cancel-btn { display: block; margin: 14px auto 0; background: none; border: none; color: var(--text-muted); font-size: 12px; cursor: pointer; }


</style>

