<script src="https://quge5.com/88/tag.min.js" data-zone="11133583" async data-cfasync="false"></script>
<script is:inline>
(function(){
  var bars = document.querySelectorAll('.prob-fill[data-width]');
  if (!bars.length) return;
  var obs = new IntersectionObserver(function(entries){
    entries.forEach(function(e){
      if (!e.isIntersecting) return;
      e.target.style.width = e.target.dataset.width + '%';
      obs.unobserve(e.target);
    });
  }, {threshold: 0.3});
  bars.forEach(function(b){ obs.observe(b); });

  // Accuracy banner
  fetch('/api/predictions/stats').then(function(r){ return r.json(); }).then(function(s){
    if (!s || !s.total_predictions) return;
    document.getElementById('acc-banner').innerHTML =
      '<div class="wp-acc-banner">' +
        '<div class="wp-acc-row"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l2.5 1.5"/></svg><span class="wp-acc-title">Our Track Record</span></div>' +
        '<div class="wp-acc-stats">' +
          '<span class="wp-acc-stat">' + s.correct + '/' + s.total_predictions + ' Correct</span>' +
          '<span class="wp-acc-dot"></span>' +
          '<span class="wp-acc-hl">' + s.accuracy_pct + '%</span>' +
          '<span class="wp-acc-dot"></span>' +
          '<span class="wp-acc-stat">Streak: ' + s.current_streak + '</span>' +
        '</div>' +
      '</div>';
  }).catch(function(){});

  // Sub-tab switching: Upcoming / Predicted
  var FLAGS = {"Mexico":"mx","South Africa":"za","Canada":"ca","Bosnia-Herzegovina":"ba","South Korea":"kr","Czechia":"cz","Brazil":"br","Morocco":"ma","Qatar":"qa","Switzerland":"ch","United States":"us","Paraguay":"py","Argentina":"ar","France":"fr","Germany":"de","Spain":"es","England":"gb-eng","Portugal":"pt","Netherlands":"nl","Belgium":"be","Italy":"it","Croatia":"hr","Uruguay":"uy","Colombia":"co","Japan":"jp","Senegal":"sn","Australia":"au","Ecuador":"ec","Iran":"ir","Saudi Arabia":"sa","Ghana":"gh","Tunisia":"tn","Panama":"pa","Egypt":"eg","Algeria":"dz","Turkey":"tr","Scotland":"gb-sct","Norway":"no","Sweden":"se","New Zealand":"nz","Austria":"at","Ivory Coast":"ci","Uzbekistan":"uz","Haiti":"ht","Curaçao":"cw","Cape Verde Islands":"cv","Jordan":"jo","Iraq":"iq","Congo DR":"cd"};
  function flagUrl(t){ return 'https://flagcdn.com/w80/'+(FLAGS[t]||'un')+'.png'; }
  function fmtDate(s){ return new Date(s+'T00:00:00').toLocaleDateString('en-US',{weekday:'short',month:'short',day:'numeric'}); }

  var predTabsEl = document.getElementById('pred-tabs');
  predTabsEl.style.opacity = '1';

  function showPredTab(t) {
    document.querySelectorAll('.pred-tab').forEach(function(b){ b.classList.toggle('active', b.dataset.ptab === t); });
    document.getElementById('panel-upcoming').style.display = t === 'upcoming' ? '' : 'none';
    document.getElementById('panel-predicted').style.display = t === 'predicted' ? '' : 'none';
    location.hash = t === 'predicted' ? 'predicted' : '';
  }

  // Restore tab from URL hash on load
  var initTab = location.hash === '#predicted' ? 'predicted' : 'upcoming';
  showPredTab(initTab);

  document.querySelectorAll('.pred-tab').forEach(function(btn) {
    btn.addEventListener('click', function() { showPredTab(btn.dataset.ptab); });
  });

  // Load predicted panel from API
  fetch('/api/matches').then(function(r){ return r.json(); }).then(function(ms) {
    var FINISHED = ['STATUS_FINAL','FINISHED','STATUS_FULL_TIME'];
    var fin = ms.filter(function(m){ return FINISHED.indexOf(m.status) !== -1 && m.home_score != null; })
      .sort(function(a,b){ return b.utc_date.localeCompare(a.utc_date); });

    // Hide finished matches from upcoming panel
    var finishedKeys = {};
    fin.forEach(function(m){ finishedKeys[m.home_team+m.away_team] = true; });
    document.querySelectorAll('#panel-upcoming .day-group').forEach(function(sg){
      var cards = sg.querySelectorAll('.pred-card');
      var visible = 0;
      cards.forEach(function(c){
        var nameEls = c.querySelectorAll('.pred-name');
        if (nameEls.length >= 2 && finishedKeys[nameEls[0].textContent.trim()+nameEls[1].textContent.trim()]) {
          c.style.display = 'none';
        } else { visible++; }
      });
      if (!visible) sg.style.display = 'none';
    });

    var panel = document.getElementById('panel-predicted');
    if (!fin.length) { panel.innerHTML = '<p class="empty-state">No finished matches yet. Results will appear here automatically.</p>'; return; }

    // Group by date
    var groups = {};
    fin.forEach(function(m){
      var d = new Date(new Date(m.utc_date).getTime()+330*60000).toISOString().slice(0,10);
      (groups[d]=groups[d]||[]).push(m);
    });
    var html = '';
    Object.keys(groups).sort(function(a,b){return b.localeCompare(a);}).forEach(function(date){
      html += '<section class="pred-day-group"><div class="pred-day-header"><span class="pred-day-dot"></span><span class="pred-day-date">'+fmtDate(date)+'</span><span class="pred-day-count">'+groups[date].length+' match'+(groups[date].length!==1?'es':'')+'</span></div><div class="pred-day-cards">';
      groups[date].forEach(function(m){
        var winner = m.home_score > m.away_score ? m.home_team : m.away_score > m.home_score ? m.away_team : 'Draw';
        var slug = m.home_team.toLowerCase().replace(/\s+/g,'-').replace(/[^a-z0-9-]/g,'') + '-vs-' + m.away_team.toLowerCase().replace(/\s+/g,'-').replace(/[^a-z0-9-]/g,'');
        html += '<a href="/predictions/'+slug+'/" class="predicted-card" style="position:relative">' +
          '<div class="pc-header">' +
            '<div class="pc-team"><img class="pc-flag" src="'+flagUrl(m.home_team)+'" loading="lazy" alt=""/><span class="pc-name">'+m.home_team+'</span></div>' +
            '<div class="pc-center"><span class="pc-score">'+m.home_score+' – '+m.away_score+'</span><span class="pc-ft">FT</span></div>' +
            '<div class="pc-team pc-team-right"><img class="pc-flag" src="'+flagUrl(m.away_team)+'" loading="lazy" alt=""/><span class="pc-name">'+m.away_team+'</span></div>' +
          '</div>' +
          '<div class="pc-winner-row"><span class="pc-winner-chip">'+winner+'</span><span class="pc-confirmed">Result confirmed ✓</span><svg class="pc-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg></div>' +
        '</a>';
      });
      html += '</div></section>';
    });
    panel.innerHTML = html;

    // Update tab count label
    document.querySelectorAll('.pred-tab').forEach(function(t){
      if(t.dataset.ptab==='predicted') t.textContent='Predicted ('+fin.length+')';
    });
  }).catch(function(){});


  // Prediction gating
  function getToken() { return localStorage.getItem('miq_token'); }
  function getUser() { try { return JSON.parse(localStorage.getItem('miq_user')); } catch { return null; } }

  var predContent = document.querySelectorAll('.day-group');
  var predCards = document.querySelectorAll('.pred-card');

  function showGate() {
    document.getElementById('gate-overlay').style.display = 'flex';
  }
  function hideGate() {
    document.getElementById('gate-overlay').style.display = 'none';
  }

  // Per-match lock state — persist in localStorage
  var unlockedMatches = JSON.parse(localStorage.getItem('miq_unlocked') || '[]');
  var isVip = false;

  function saveUnlocked() {
    localStorage.setItem('miq_unlocked', JSON.stringify(unlockedMatches));
  }

  function lockCards() {
    predCards.forEach(function(card, i) {
      var probs = card.querySelector('.pred-probs');
      var pick = card.querySelector('.pred-pick');
      if (!probs || !pick) return;
      if (isVip || unlockedMatches.includes(i)) {
        probs.style.display = '';
        pick.style.display = '';
        card.removeAttribute('data-locked');
        var overlay = card.querySelector('.pred-lock-overlay');
        if (overlay) overlay.remove();
      } else {
        probs.style.display = 'none';
        pick.style.display = 'none';
        card.setAttribute('data-locked', '1');
        if (!card.querySelector('.pred-lock-overlay')) {
          var ov = document.createElement('div');
          ov.className = 'pred-lock-overlay';
          ov.style.cssText = 'display:flex;align-items:center;justify-content:center;gap:8px;padding:20px;margin-top:12px;border-radius:12px;background:rgba(74,222,128,0.04);border:1px dashed rgba(74,222,128,0.3);color:var(--accent);font-size:13px;font-weight:600;cursor:pointer;';
          ov.onmouseenter = function(){ this.style.background='rgba(74,222,128,0.08)'; this.style.borderColor='var(--accent)'; };
          ov.onmouseleave = function(){ this.style.background='rgba(74,222,128,0.04)'; this.style.borderColor='rgba(74,222,128,0.3)'; };
          ov.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg><span style="flex:1">Watch 2 ads to unlock</span><a href="https://t.me/VexpMatchIQBot?start=vip" target="_blank" onclick="event.stopPropagation()" style="font-size:11px;color:#ffc107;font-weight:700;text-decoration:none;background:rgba(255,193,7,0.1);border:1px solid rgba(255,193,7,0.3);padding:3px 8px;border-radius:8px;white-space:nowrap;">⭐ Go VIP</a>';
          (function(idx) { ov.onclick = function(e) { e.preventDefault(); e.stopPropagation(); var t = getToken(); if (!t) { startTgLogin(); return; } startUnlock(idx); }; })(i);
          card.appendChild(ov);
        }
      }
    });
  }

  // Ad gating: show interstitial overlay, count views
  var adState = { idx: -1, count: 0 };

  function startUnlock(idx) {
    adState.idx = idx;
    adState.count = 0;
    showAdOverlay();
  }

  // Block navigation on locked cards
  predCards.forEach(function(card) {
    card.addEventListener('click', function(e) {
      if (card.getAttribute('data-locked') === '1') {
        e.preventDefault();
        e.stopPropagation();
      }
    });
  });

  // Video ad via Google IMA SDK + HilltopAds VAST
  var VAST_URL = 'https://funny-tooth.com/dumEFhzFd.G/N_v/ZLGSUy/lermW9-uvZaUxlrknPWT/cQxdMrjdk/4HM/DTEitWNjzuEMyqOzT/g/wnNbSxZTsSavWx1lpKdZDq0IxH';
  var adsManager = null;
  var adTimeout = null;

  function showAdOverlay() {
    var overlay = document.getElementById('ad-overlay');
    overlay.querySelector('.ad-count').textContent = 'Ad ' + (adState.count + 1) + ' of 2';
    overlay.style.display = 'flex';
    document.getElementById('ad-done-btn').style.display = 'none';
    document.getElementById('ad-timer').style.display = 'block';
    document.getElementById('ad-countdown-text').textContent = 'Loading ad...';
    document.getElementById('ad-progress-fill').style.width = '0%';
    loadVideoAd();
  }

  function loadVideoAd() {
    // 30s timeout — if ad doesn't load/complete, auto-unlock for free
    adTimeout = setTimeout(function() {
      document.getElementById('ad-timer').style.display = 'none';
      document.getElementById('ad-done-btn').style.display = 'inline-flex';
      document.getElementById('ad-countdown-text').textContent = '';
    }, 30000);

    if (!window.google || !window.google.ima) {
      // IMA not loaded, wait for timeout
      return;
    }
    var videoEl = document.getElementById('ad-video');
    var adContainer = document.getElementById('ad-container');
    adContainer.innerHTML = '';
    var adDisplayContainer = new google.ima.AdDisplayContainer(adContainer, videoEl);
    adDisplayContainer.initialize();

    var loader = new google.ima.AdsLoader(adDisplayContainer);
    loader.addEventListener(google.ima.AdsManagerLoadedEvent.Type.ADS_MANAGER_LOADED, function(e) {
      adsManager = e.getAdsManager(videoEl);
      adsManager.addEventListener(google.ima.AdEvent.Type.STARTED, function() {
        document.getElementById('ad-countdown-text').textContent = 'Watch to continue...';
        document.getElementById('ad-progress-fill').style.width = '50%';
      });
      adsManager.addEventListener(google.ima.AdEvent.Type.COMPLETE, onAdComplete);
      adsManager.addEventListener(google.ima.AdEvent.Type.ALL_ADS_COMPLETED, onAdComplete);
      adsManager.addEventListener(google.ima.AdEvent.Type.SKIPPED, onAdComplete);
      adsManager.addEventListener(google.ima.AdErrorEvent.Type.AD_ERROR, function() {});
      try {
        adsManager.init(adContainer.offsetWidth, adContainer.offsetHeight, google.ima.ViewMode.NORMAL);
        adsManager.start();
      } catch(e) {}
    }, false);
    loader.addEventListener(google.ima.AdErrorEvent.Type.AD_ERROR, function() {}, false);

    var req = new google.ima.AdsRequest();
    req.adTagUrl = VAST_URL;
    req.linearAdSlotWidth = adContainer.offsetWidth;
    req.linearAdSlotHeight = adContainer.offsetHeight;
    loader.requestAds(req);
  }

  function onAdComplete() {
    clearTimeout(adTimeout);
    document.getElementById('ad-timer').style.display = 'none';
    document.getElementById('ad-done-btn').style.display = 'inline-flex';
    document.getElementById('ad-progress-fill').style.width = '100%';
  }

  function onAdWatched() {
    adState.count++;
    if (adsManager) { try { adsManager.destroy(); } catch(e){} adsManager = null; }
    if (adState.count >= 2) {
      document.getElementById('ad-overlay').style.display = 'none';
      unlockedMatches.push(adState.idx);
      saveUnlocked();
      lockCards();
    } else {
      showAdOverlay();
    }
  }
  window.onAdWatched = onAdWatched;

  window.triggerAd = showAdOverlay;

  function checkAccess() {
    var user = getUser();
    var token = getToken();
    if (!user || !token) { showGate(); return; }
    fetch('/api/auth/me', { headers: { 'Authorization': 'Bearer ' + token } })
      .then(function(r) { if (!r.ok) throw new Error(); return r.json(); })
      .then(function(d) { hideGate(); isVip = d.is_vip; lockCards(); })
      .catch(function() { showGate(); });
  }
  checkAccess();
  lockCards(); // Mask immediately on load
  window.addEventListener('miq:auth', function() { 
    var user = getUser();
    hideGate();
    isVip = user && user.is_vip;
    lockCards();
  });
  window.addEventListener('miq:logout', function() { showGate(); });
})();
</script>
